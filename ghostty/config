# Font
font-family = JetBrainsMono Nerd Font
font-size = 16
font-style = Regular
font-style-bold = Bold
font-style-italic = Italic
font-style-bold-italic = Bold Italic
adjust-cell-height = 2

# Window
window-padding-x = 16
window-padding-y = 12
window-decoration = true
background-opacity = 0.9
background-blur-radius = 20
macos-option-as-alt = true
window-title-font-family = JetBrainsMono Nerd Font

# Cursor
cursor-style = bar
cursor-style-blink = true

# Scrollback
scrollback-limit = 50000

# Mouse
mouse-hide-while-typing = true
copy-on-select = clipboard

# Shell
term = xterm-256color

# Tokyo Night color scheme
background = 1a1b26
foreground = c0caf5
cursor-color = c0caf5
cursor-text = 1a1b26
selection-background = 33467c
selection-foreground = c0caf5

# Normal colors
palette = 0=#15161e
palette = 1=#f7768e
palette = 2=#9ece6a
palette = 3=#e0af68
palette = 4=#7aa2f7
palette = 5=#bb9af7
palette = 6=#7dcfff
palette = 7=#a9b1d6

# Bright colors
palette = 8=#414868
palette = 9=#f7768e
palette = 10=#9ece6a
palette = 11=#e0af68
palette = 12=#7aa2f7
palette = 13=#bb9af7
palette = 14=#7dcfff
palette = 15=#c0caf5
